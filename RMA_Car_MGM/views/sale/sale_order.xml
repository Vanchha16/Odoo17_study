<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record model="ir.ui.view" id="view_sale_order_tree">
        <field name="name">sale_order_tree</field>
        <field name="model">rma.sale_order</field>
        <field name="arch" type="xml">
            <tree string="Sales Order">
                <field name="sale_code"/>
                <field name="car_id"/>
                <field name="seller_id" string="Sale By"/>
                <field name="customer_id"/>
                <field name="commission_rate"/>
                <field name="currency_id" invisible="1"/>
                <field name="commission_amount" string="Commission Amount $"  readonly="True" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                <field name="sale_date"/>
                <field name="status" widget="badge"
                        decoration-it="status == 'draft'"
                        decoration-info="status == 'delivered'"
                        decoration-success="status == 'done'"
                        decoration-danger="status == 'cancelled'"/>
            </tree>
        </field>
    </record>

    <record model="ir.ui.view" id="view_sale_order_form">
        <field name="name">sale_order_form</field>
        <field name="model">rma.sale_order</field>
        <field name="arch" type="xml">
            <form string="Sales Order">
                <header>
                    <button name="action_save_sale"
                        string="Save"
                        type="object"
                        class="btn-primary"/>
                    <button name="action_delivered"
                        string="Delivered"
                        type="object"
                        class="btn-secondary"/>
                    <button name="action_done"
                        string="Done"
                        type="object"
                        class="btn-secondary"/>
                    <button name="action_cancel"
                        string="Cancel"
                        type="object"
                        class="btn-secondary"/>
                    <button name="action_print_invoice"
                        string="Print Invoice"
                        type="object"
                        class="btn-secondary"
                        invisible="status == 'draft'"/>
                    <field name="status" widget="statusbar"/>
                </header>
                <sheet>
                     <group>
                        <group string="Car Info">
                            <field name="sale_code" readonly="True"/>
                            <field name="car_id"/>
                            <field name="qty"/>
                            <field name="car_qty_available" readonly="True"/>
                            <field name="sale_date"/>
                            <field name="seller_id"/>
                            <field name="customer_id"/>
                        </group>
                        <group string="Order Info">
                            <field name="brand_id" widget="many2one_avatar" readonly="True"/>
                            <field name="car_price" readonly="True"/>
                            <field name="commission_rate"/>
                            <field name="commission_amount" readonly="True"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
            </form>
        </field>
    </record>

    <record id="view_sale_order_graph" model="ir.ui.view">
        <field name="name">sale_order_graph</field>
        <field name="model">rma.sale_order</field>
        <field name="arch" type="xml">
            <graph string="Sales Analysis" type="bar">
                <field name="seller_id" type="row"/>
                <field name="commission_amount" type="measure"/>
                <field name="qty" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_sale_order_pivot" model="ir.ui.view">
        <field name="name">sale_order_pivot</field>
        <field name="model">rma.sale_order</field>
        <field name="arch" type="xml">
            <pivot string="Sales Summary" display_quantity="true">
                <field name="brand_id" type="row"/>
                <field name="seller_id" type="col"/>
                <field name="commission_amount" type="measure"/>
                <field name="qty" type="measure"/>
            </pivot>
        </field>
    </record>

    <record model="ir.actions.act_window" id="action_sale_order">
        <field name="name">Sales Order</field>
        <field name="res_model">rma.sale_order</field>
        <field name="view_mode">tree,form,graph,pivot</field>
        <field name="view_ids" eval="[
                    Command.clear(),
                    (0, 0, {'view_mode': 'tree', 'view_id': ref('view_sale_order_tree')}),
                    (0, 0, {'view_mode': 'form', 'view_id': ref('view_sale_order_form')}),
                    (0, 0, {'view_mode': 'graph', 'view_id': ref('view_sale_order_graph')}),
                    (0, 0, {'view_mode': 'pivot', 'view_id': ref('view_sale_order_pivot')})
                ]"/>
    </record>

    <record model="ir.actions.act_window" id="action_sale_dashboard">
        <field name="name">Sales Dashboard</field>
        <field name="res_model">rma.sale_order</field>
        <field name="view_mode">graph,pivot,tree</field>
        <field name="view_ids" eval="[
                    Command.clear(),
                    (0, 0, {'view_mode': 'graph', 'view_id': ref('view_sale_order_graph')}),
                    (0, 0, {'view_mode': 'pivot', 'view_id': ref('view_sale_order_pivot')}),
                    (0, 0, {'view_mode': 'tree', 'view_id': ref('view_sale_order_tree')})
                ]"/>
    </record>
</odoo>