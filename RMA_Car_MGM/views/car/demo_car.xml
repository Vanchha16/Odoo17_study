<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record model="ir.ui.view" id="view_car_demo_tree">
        <field name="name">car_view_demo_tree</field>
        <field name="model">rma.demo.car</field>
        <field name="arch" type="xml">
            <tree string="Car For Demo">
                <field name="car_id"/>
                <field name="qty_demo"/>
                <field name="models"/>
                <field name="years"/>
                <field name="colors"/>
                <field name="engines"/>
                <field name="brand_id" widget="many2one_avatar" />
                <field name="status" widget="badge"
                        decoration-success="status == 'active'"
                        decoration-it="status == 'inactive'"/>
            </tree>
        </field>
    </record>
    <record model="ir.ui.view" id="view_car_demo_form">
        <field name="name">car_view_demo_form</field>
        <field name="model">rma.demo.car</field>
        <field name="arch" type="xml">
            <form string="Car For Demo">
                <sheet>
                    <group>
                        <field name="car_id"/>
                        <field name="qty_demo"/>
                        <field name="models"/>
                        <field name="years"/>
                        <field name="colors"/>
                        <field name="engines"/>
                    </group>
                    <group>
                        <field name="brand_id" widget="many2one_avatar" />
                        <field name="status"
                                decoration-success="status == 'active'"
                                decoration-it="status == 'inactive'"/>

                    </group>

                </sheet>
            </form>
        </field>
    </record>

    <record model="ir.actions.act_window" id="action_demo_car">
        <field name="name">Car For Demo</field>
        <field name="res_model">rma.demo.car</field>
        <field name="context"/>
        <field name="view_mode">tree,form</field>
        <field name="view_ids" eval="[
                    Command.clear(),
                    (0, 0, {'view_mode': 'tree', 'view_id': ref('view_car_demo_tree')}),
                    (0, 0, {'view_mode': 'form', 'view_id': ref('view_car_demo_form')})
                ]"/>
    </record>

</odoo>