<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record model="ir.ui.view" id="view_school_student_search">
        <field name="name">school.student.search</field>
        <field name="model">school.student</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" filter_domain="['|', '|',
                        ('name', 'ilike', self),
                        ('phone', 'ilike', self),
                        ('email', 'ilike', self)]" string="Search"/>
                <separator/>
                <!-- Use for spacing filter-->
                <filter name="enrolled" string="Enrolled" domain="[('status', '=', 'enrolled')]"/>
                <filter name="cancelled" string="Canceled" domain="[('status', '=', 'cancelled')]"/>
                <group expand="1" string="Group By">
                    <filter name="group_major" string="Major" context="{'group_by': 'major_id'}"/>
                    <filter name="group_group" string="Group" context="{'group_by': 'group_id'}"/>
                </group>
                <searchpanel >
                    <field name="major_id"
                        string="🎓 Major"
                        enable_counters="1"
                        />
                    <field name="group_id"
                        string="👥 Group"
                        enable_counters="1"
                       />
                </searchpanel>
            </search>
        </field>
    </record>
    <record id="view_school_student_kanban" model="ir.ui.view">
        <field name="name">school.student.kanban</field>
        <field name="model">school.student</field>
        <field name="arch" type="xml">
            <kanban default_group_by="group_id" records_draggable="true" quick_create="true">
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="age"/>
                <field name="major_id"/>
                <field name="group_id"/>
                <field name="status"/>
                <field name="note"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click card shadow-sm border-0 h-100 mb-2">
                            <!-- Header -->
                            <div class="card-header bg-primary text-white">
                                <div class="d-flex justify-content-between align-items-center">
                                    <strong>
                                        <field name="name"/>
                                    </strong>
                                    <field name="status"
                                           widget="badge"
                                           decoration-success="status == 'enrolled'"
                                           decoration-warning="status == 'cancelled'"/>
                                </div>
                            </div>

                            <!-- Body -->
                            <div class="card-body">

                                <div class="mb-2">
                                    <i class="fa fa-users text-primary me-2"/>
                                    <strong>Group:</strong>
                                    <field name="group_id"/>
                                </div>

                                <div class="mb-2">
                                    <i class="fa fa-graduation-cap text-success me-2"/>
                                    <strong>Major:</strong>
                                    <field name="major_id"/>
                                </div>

                                <div class="mb-2">
                                    <i class="fa fa-envelope text-info me-2"/>
                                    <field name="email"/>
                                </div>

                                <div class="mb-2">
                                    <i class="fa fa-phone text-warning me-2"/>
                                    <field name="phone"/>
                                </div>

                                <div class="mb-2">
                                    <i class="fa fa-calendar text-danger me-2"/>
                                    <strong>Age:</strong>
                                    <field name="age"/>
                                </div>

                                <!-- Inactive Reason -->
                                <div class="alert alert-warning py-2 mt-3"
                                     invisible="status != 'cancelled'">
                                    <strong>Cancelled Note:</strong>
                                    <field name="note"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record model="ir.ui.view" id="view_school_student_tree">
        <field name="name">school.student.tree</field>
        <field name="model">school.student</field>
        <field name="arch" type="xml">
            <tree string="Students">
                <header>
                    <button name="action_generate_payment" type="object"
                            string="Generate Payment" class="btn-primary"/>
                </header>
                <field name="name"/>
                <field name="age"/>
                <field name="gender"/>
                <field name="dob"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="group_id" string="Group" />
                <field name="status" string="Status" widget="badge" decoration-success="status == 'enrolled'"
                       decoration-warning="status == 'cancelled'"/>
                <field name="name_major_code" string="Major"/>
                <field name="note" string="Note" optional="hide"/>
            </tree>
        </field>
    </record>
    <record model="ir.ui.view" id="view_school_student_form">
        <field name="name">school.student.form</field>
        <field name="model">school.student</field>
        <field name="arch" type="xml">
            <form string="Student">
                <header>
                    <button name="action_set_draft" string="Draft"
                            type="object"
                            invisible="status == 'enrolled'"/>
                    <button name="action_set_cancelled" string="Cancel"
                            type="object"
                            invisible="status != 'enrolled'"/>
                    <field name="status" widget="statusbar"
                           statusbar_visible="draft,enrolled,cancelled"/>
                </header>
                <sheet>
                    <group string="Student Code">
                        <h1>
                             <field name="student_code" string="Student Code" readonly="1"/>
                        </h1>

                    </group>
                    <div class="oe_title">

                        <h1>
                            <field name="name" placeholder="Student full name..."/>

                        </h1>
                    </div>

                    <group string="Personal Information">
                        <group>
                            <field name="user_id"   />
                            <field name="gender"/>
                            <field name="dob" string="Date of Birth"/>
                            <field name="age" string="Age"/>
                        </group>
                        <group>
                            <field name="email" string="Email"/>
                            <field name="phone" string="Phone"/>
                            <field name="note" string="Note" placeholder="Note The reason"
                                   invisible="status != 'cancelled'"/>
<!--                            <field name="check"/>-->
                        </group>
                    </group>

                    <group string="Academic Information">
                        <group>
                            <field name="major_id" string="Major" />
                            <field name="group_id" string="Group"/>
                        </group>
                        <group>
                            <field name="academic_year_id" string="Academic Year"/>
                            <field name="semester_id" string="Semester"/>
                            <field name="program_year_id" string="Program Year"/>
                        </group>
                    </group>
                </sheet>

                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>
    <record model="ir.actions.act_window" id="action_school_student">
        <field name="name">Students</field>
        <field name="view_ids" eval="[
            Command.clear(),
            (0, 0, {'view_mode': 'kanban', 'view_id': ref('view_school_student_kanban')}),
            (0, 0, {'view_mode': 'tree',   'view_id': ref('view_school_student_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_school_student_form')}),
        ]"/>
        <field name="res_model">school.student</field>
        <field name="view_mode">kanban,tree,form</field>

    </record>
    <record id="view_student_inactive_wizard_form"
            model="ir.ui.view">
        <field name="name">school.inactive.student.form</field>
        <field name="model">school.inactive.student</field>
        <field name="arch" type="xml">
            <form string="Set Student canceled">
                <group>
                    <field name="student_id" invisible="0"/>
                    <field name="note"
                           placeholder="Enter the reason..."/>
                </group>

                <footer>
                    <button name="action_confirm"
                            string="Confirm"
                            type="object"
                            class="btn-primary"/>

                    <button string="Cancel"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>