<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record model="ir.ui.view" id="view_school_academic_year_tree">
        <field name="name">school.academic.year.tree</field>
        <field name="model">school.academic.year</field>
        <field name="arch" type="xml">
            <tree string="Academic Years">
                <field name="name"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="status"/>
            </tree>
        </field>
    </record>
    <record model="ir.ui.view" id="view_school_academic_year_kanban">
        <field name="name">school.academic.year.kanban</field>
        <field name="model">school.academic.year</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="status"/>

                <!-- Remove these until relations are confirmed -->
                <!-- <field name="semester_count"/> -->
                <!-- <field name="group_count"/> -->
                <!-- <field name="progress"/> -->
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <span class="fa fa-university fa-2x text-muted"/>
                                <div class="o_dropdown_kanban dropdown">
                                    <a class="dropdown-toggle o-no-caret btn" data-bs-toggle="dropdown">
                                        <span class="fa fa-ellipsis-v"/>
                                    </a>
                                    <div class="dropdown-menu" role="menu">
                                        <a role="menuitem" type="edit" class="dropdown-item">Edit</a>
                                        <a role="menuitem" type="delete" class="dropdown-item">Delete</a>
                                    </div>
                                </div>
                            </div>

                            <strong><field name="name"/></strong>

                            <div class="text-muted small mt-1">
                                <span class="fa fa-calendar-o me-1"/>
                                <field name="start_date"/> — <field name="end_date"/>
                            </div>

                            <hr class="mt-2 mb-2"/>

                            <div class="d-flex align-items-center justify-content-between">
<!--                                <field name="status" widget="badge"-->
<!--                                    decoration-success="status == 'active'"-->
<!--                                    decoration-secondary="status == 'archived'"-->
<!--                                    decoration-warning="status == 'inactive'"/>-->
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    <record model="ir.ui.view" id="view_school_academic_year_form">
        <field name="name">school.academic.year.form</field>
        <field name="model">school.academic.year</field>
        <field name="arch" type="xml">
            <form string="Academic Year">
                <sheet>

                    <group>
                        <field name="name"/>
                        <field name="start_date"/>
                        <field name="end_date"/>
                        <field name="status"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>
    <record model="ir.actions.act_window" id="action_school_academic_year">
        <field name="name">Academic Years</field>
        <field name="res_model">school.academic.year</field>
        <field name="view_mode">tree,kanban,form</field>
        <field name="view_ids" eval="[
            Command.clear(),
            (0, 0, {'view_mode': 'tree', 'view_id': ref('view_school_academic_year_tree')}),
            (0, 0, {'view_mode': 'kanban', 'view_id': ref('view_school_academic_year_kanban')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_school_academic_year_form')})
        ]"/>
    </record>
</odoo>