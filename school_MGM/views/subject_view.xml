<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record model="ir.ui.view" id="view_school_subject_tree">
        <field name="name">school.subject.tree</field>
        <field name="model">school.subject</field>
        <field name="arch" type="xml">
            <tree string="Subjects" editable="top">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="teacher_ids" string="Teacher" />
            </tree>
        </field>
    </record>

    <record model="ir.actions.act_window" id="action_school_subject">
        <field name="name">Subjects</field>
        <field name="view_ids" eval="[
            Command.clear(),
            (0, 0, {'view_mode': 'tree', 'view_id': ref('view_school_subject_tree')})
        ]"/>
        <field name="res_model">school.subject</field>
        <field name="view_mode">tree</field>
    </record>
</odoo>