<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>

        <record id="view_purchase_order_form_approved_by" model="ir.ui.view">
            <field name="name">purchase.order.form.approved.by</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.purchase_order_form"/>
            <field name="arch" type="xml">

                <xpath expr="//field[@name='date_approve']" position="after">
                    <field name="approved_by_id" readonly="1"/>
                </xpath>

            </field>
        </record>

    </data>
</odoo>