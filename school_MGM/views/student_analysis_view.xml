<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- SEARCH VIEW — you have none, which means no filtering at all -->
    <record id="view_student_analysis_search" model="ir.ui.view">
        <field name="name">school.student.analysis.search</field>
        <field name="model">school.student.analysis</field>
        <field name="arch" type="xml">
            <search string="Student Analysis">
                <field name="student_name"/>
                <field name="major_id"/>
                <field name="group_id"/>

                <filter name="enrolled"  string="Enrolled"
                        domain="[('status', '=', 'enrolled')]"/>
                <filter name="draft"     string="Draft"
                        domain="[('status', '=', 'draft')]"/>
                <filter name="canceled"  string="Canceled"
                        domain="[('status', '=', 'cancelled')]"/>
                <separator/>

                <group expand="1" string="Group By">
                    <filter name="by_major"        string="Major"
                            context="{'group_by': 'major_id'}"/>
                    <filter name="by_group"        string="Group"
                            context="{'group_by': 'group_id'}"/>
                    <filter name="by_status"       string="Status"
                            context="{'group_by': 'status'}"/>
                    <filter name="by_program_year" string="Program Year"
                            context="{'group_by': 'program_year_id'}"/>
                    <filter name="by_semester"     string="Semester"
                            context="{'group_by': 'semester_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- LIST VIEW — removed student_count (meaningless per row) -->
    <record id="view_student_analysis_tree" model="ir.ui.view">
        <field name="name">school.student.analysis.tree</field>
        <field name="model">school.student.analysis</field>
        <field name="arch" type="xml">
            <tree string="Student Analysis">
                <field name="student_name"/>
                <field name="gender"/>
                <field name="age"/>
                <field name="major_id"/>
                <field name="group_id"/>
                <field name="program_year_id"/>
                <field name="semester_id"/>
                <field name="academic_year_id"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'enrolled'"
                       decoration-warning="status == 'draft'"
                       decoration-danger="status == 'cancelled'"/>
            </tree>
        </field>
    </record>

    <!-- PIVOT VIEW — added age as a second measure -->
    <record id="view_student_analysis_pivot" model="ir.ui.view">
        <field name="name">school.student.analysis.pivot</field>
        <field name="model">school.student.analysis</field>
        <field name="arch" type="xml">
            <pivot string="Student Analysis" disable_linking="True">
                <field name="major_id"       type="row"/>
                <field name="program_year_id" type="row"/>
                <field name="status"         type="col"/>
                <field name="student_count"  type="measure"/>
                <field name="age"            type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- GRAPH VIEW — added a second graph grouping by status -->
    <record id="view_student_analysis_graph" model="ir.ui.view">
        <field name="name">school.student.analysis.graph</field>
        <field name="model">school.student.analysis</field>
        <field name="arch" type="xml">
            <graph string="Student Analysis" type="bar">
                <field name="major_id"      type="row"/>
                <field name="status"        type="col"/>
                <field name="student_count" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- ACTION — explicit view_ids + search view wired up -->
    <record id="action_student_analysis" model="ir.actions.act_window">
        <field name="name">Student Analysis</field>
        <field name="res_model">school.student.analysis</field>
        <field name="view_mode">pivot,graph,tree</field>
        <field name="view_id" ref="view_student_analysis_search"/>
        <field name="context">{
            'search_default_by_major': 1
        }</field>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'pivot', 'view_id': ref('view_student_analysis_pivot')}),
            (0, 0, {'view_mode': 'graph', 'view_id': ref('view_student_analysis_graph')}),
            (0, 0, {'view_mode': 'tree',  'view_id': ref('view_student_analysis_tree')})
        ]"/>
    </record>

</odoo>