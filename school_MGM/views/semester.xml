<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record model="ir.ui.view" id="view_school_semester_tree">
        <field name="name">school.semester.tree</field>
        <field name="model">school.semester</field>
        <field name="arch" type="xml">
            <tree string="Semesters">
                <field name="name"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="midterm_date"/>
                <field name="final_date"/>
                <field name="academic_year_id"/>
            </tree>
        </field>
    </record>

    <record model="ir.ui.view" id="view_school_semester_kanban">
        <field name="name">school.semester.kanban</field>
        <field name="model">school.semester</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" default_group_by="academic_year_id" sample="1">
                <field name="name"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="midterm_date"/>
                <field name="final_date"/>
                <field name="academic_year_id"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click o_kanban_record d-flex flex-column p-3 mb-2 bg-white rounded shadow-sm border-top border-primary border-4">

                            <div class="o_kanban_record_top mb-2">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title text-primary fs-5">
                                        <field name="name"/>
                                    </strong>
                                </div>
                            </div>

                            <div class="o_kanban_record_body text-muted small">
                                <div class="mb-2" t-if="record.academic_year_id.raw_value">
                                    <span class="badge bg-secondary-light text-primary border px-2 py-1">
                                        <i class="fa fa-graduation-cap me-1"/>
                                        <field name="academic_year_id"/>
                                    </span>
                                </div>

                                <div class="row g-2 mt-1">
                                    <div class="col-6" t-if="record.start_date.raw_value">
                                        <span class="text-uppercase fw-bold d-block text-xxs tracking-wider">Start
                                            Date</span>
                                        <span class="text-dark"><i
                                                class="fa fa-calendar-plus-o me-1 text-success"/> <field
                                                name="start_date"/></span>
                                    </div>
                                    <div class="col-6" t-if="record.end_date.raw_value">
                                        <span class="text-uppercase fw-bold d-block text-xxs tracking-wider">End
                                            Date</span>
                                        <span class="text-dark"><i
                                                class="fa fa-calendar-minus-o me-1 text-danger"/> <field
                                                name="end_date"/></span>
                                    </div>

                                    <div class="col-6 mt-2" t-if="record.midterm_date.raw_value">
                                        <span class="text-uppercase fw-bold d-block text-xxs tracking-wider">
                                            Midterm</span>
                                        <span class="text-dark"><i
                                                class="fa fa-hourglass-half me-1 text-warning"/> <field
                                                name="midterm_date"/></span>
                                    </div>
                                    <div class="col-6 mt-2" t-if="record.final_date.raw_value">
                                        <span class="text-uppercase fw-bold d-block text-xxs tracking-wider">Final
                                            Exam</span>
                                        <span class="text-dark"><i class="fa fa-trophy me-1 text-info"/> <field
                                                name="final_date"/></span>
                                    </div>
                                </div>
                            </div>

                            <div class="o_kanban_record_bottom d-flex justify-content-between align-items-center mt-3 pt-2 border-top-dashed">
                                <div class="oe_kanban_bottom_left">
                                </div>
                                <div class="oe_kanban_bottom_right">
                                </div>
                            </div>

                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record model="ir.ui.view" id="view_school_semester_form">
        <field name="name">school.semester.form</field>
        <field name="model">school.semester</field>
        <field name="arch" type="xml">
            <form string="Semester">
                <sheet>
                    <group>
                        <field name="academic_year_id"/>
                        <field name="name"/>
                        <field name="start_date"/>
                        <field name="end_date"/>
                        <field name="midterm_date"/>
                        <field name="final_date"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record model="ir.actions.act_window" id="action_school_semester">
        <field name="name">Semesters</field>
        <field name="res_model">school.semester</field>
        <field name="view_mode">tree,kanban,form</field>
        <field name="view_ids" eval="[
            Command.clear(),
            (0, 0, {'view_mode': 'tree', 'view_id': ref('view_school_semester_tree')}),
            (0, 0, {'view_mode': 'kanban', 'view_id': ref('view_school_semester_kanban')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_school_semester_form')})
        ]"/>
    </record>
</odoo>