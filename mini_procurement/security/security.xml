<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data noupdate="0">
        <record id="module_category_procurement" model="ir.module.category">
            <field name="name">Procurement</field>
            <field name="sequence">2</field>
        </record>

        <record id="group_procurement_user" model="res.groups">
            <field name="name">Procurement User</field>
            <field name="category_id" ref="module_category_procurement"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_procurement_manager" model="res.groups">
            <field name="name">Procurement Manager</field>
            <field name="category_id" ref="module_category_procurement"/>
            <field name="implied_ids" eval="[(4, ref('mini_procurement.group_procurement_user'))]"/>
        </record>

        <!-- Record rule: users can only see their own purchase requests -->
        <record id="rule_purchase_request_user" model="ir.rule">
            <field name="name">Purchase Request: user sees own requests only</field>
            <field name="model_id" ref="mini_procurement.model_mini_purchase_request"/>
            <field name="groups" eval="[Command.set([ref('mini_procurement.group_procurement_user')])]"/>
            <field name="domain_force">[('requested_by', '=', user.id)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Managers see all purchase requests -->
        <record id="rule_purchase_request_manager" model="ir.rule">
            <field name="name">Purchase Request: manager sees all</field>
            <field name="model_id" ref="mini_procurement.model_mini_purchase_request"/>
            <field name="groups" eval="[Command.set([ref('mini_procurement.group_procurement_manager')])]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <!-- Managers see all purchase orders -->
        <record id="rule_purchase_order_manager" model="ir.rule">
            <field name="name">Purchase Order: manager sees all</field>
            <field name="model_id" ref="mini_procurement.model_mini_purchase_order"/>
            <field name="groups" eval="[Command.set([ref('mini_procurement.group_procurement_manager')])]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>
    </data>
</odoo>