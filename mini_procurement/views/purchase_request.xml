<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record model="ir.ui.view" id="view_purchase_request_tree">
        <field name="name">purchase_request_tree</field>
        <field name="model">mini.purchase.request</field>
        <field name="arch" type="xml">
            <tree string="Purchase Requests">
                <field name="name"/>
                <field name="product_id"/>
                <field name="qty"/>
                <field name="requested_by"/>
                <field name="request_date"/>
                <field name="state" widget="badge"
                       decoration-muted="state == 'draft'"
                       decoration-warning="state == 'submitted'"
                       decoration-success="state == 'approved'"
                       decoration-danger="state == 'rejected'"/>
            </tree>
        </field>
    </record>

    <record model="ir.ui.view" id="view_purchase_request_form">
        <field name="name">purchase_request_form</field>
        <field name="model">mini.purchase.request</field>
        <field name="arch" type="xml">
            <form string="Purchase Request">
                <header>
                    <button name="action_submit"
                            string="Submit"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_approve"
                            string="Approve"
                            type="object"
                            class="btn-success"
                            invisible="state != 'submitted'"
                            groups="mini_procurement.group_procurement_manager"/>
                    <button name="action_reject"
                            string="Reject"
                            type="object"
                            class="btn-danger"
                            invisible="state != 'submitted'"
                            groups="mini_procurement.group_procurement_manager"/>
                    <button name="action_reset_draft"
                            string="Reset to Draft"
                            type="object"
                            invisible="state not in ('rejected',)"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,approved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="True"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Request Info">
                            <field name="product_id"/>
                            <field name="qty"/>
                            <field name="request_date"/>
                            <field name="requested_by"/>
                        </group>
                        <group string="Status Info">
                            <field name="purchase_order_id" readonly="True"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record model="ir.actions.act_window" id="action_purchase_request">
        <field name="name">Purchase Requests</field>
        <field name="res_model">mini.purchase.request</field>
        <field name="view_mode">tree,form</field>
        <field name="view_ids" eval="[
            Command.clear(),
            (0, 0, {'view_mode': 'tree', 'view_id': ref('view_purchase_request_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_purchase_request_form')}),
        ]"/>
    </record>

</odoo>