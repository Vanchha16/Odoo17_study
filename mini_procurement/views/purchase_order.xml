<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record model="ir.ui.view" id="view_purchase_order_tree">
        <field name="name">purchase_order_tree</field>
        <field name="model">mini.purchase.order</field>
        <field name="arch" type="xml">
            <tree string="Purchase Orders">
                <field name="name"/>
                <field name="vendor_id"/>
                <field name="order_date"/>
                <field name="currency_id" invisible="1"/>
                <field name="amount_total" widget="monetary"
                       options="{'currency_field': 'currency_id'}"/>
                <field name="state" widget="badge"
                       decoration-muted="state == 'draft'"
                       decoration-warning="state == 'confirmed'"
                       decoration-success="state == 'received'"
                       decoration-danger="state == 'cancelled'"/>
            </tree>
        </field>
    </record>

    <record model="ir.ui.view" id="view_purchase_order_form">
        <field name="name">purchase_order_form</field>
        <field name="model">mini.purchase.order</field>
        <field name="arch" type="xml">
            <form string="Purchase Order">
                <header>
                    <button name="action_confirm"
                            string="Confirm"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"
                            groups="mini_procurement.group_procurement_manager"/>
                    <button name="action_receive"
                            string="Mark as Received"
                            type="object"
                            class="btn-success"
                            invisible="state != 'confirmed'"/>
                    <button name="action_cancel"
                            string="Cancel"
                            type="object"
                            class="btn-danger"
                            invisible="state in ('received', 'cancelled')"/>
                    <button name="action_reset_draft"
                            string="Reset to Draft"
                            type="object"
                            invisible="state != 'cancelled'"
                            groups="mini_procurement.group_procurement_manager"/>
                    <button name="%(mini_procurement.action_report_purchase_order)d"
                            string="Print PO"
                            type="action"
                            class="btn-secondary"
                            invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed,received"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="True"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Order Info">
                            <field name="vendor_id"/>
                            <field name="order_date"/>
                            <field name="purchase_request_id" readonly="True"/>
                        </group>
                        <group string="Amount">
                            <field name="currency_id"/>
                            <field name="amount_total" readonly="True" widget="monetary"
                                   options="{'currency_field': 'currency_id'}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Order Lines">
                            <field name="order_line_ids">
                                <tree editable="bottom">
                                    <field name="product_id"/>
                                    <field name="qty"/>
                                    <field name="price_unit"/>
                                    <field name="currency_id" invisible="1"/>
                                    <field name="subtotal" readonly="True" widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record model="ir.actions.act_window" id="action_purchase_order">
        <field name="name">Purchase Orders</field>
        <field name="res_model">mini.purchase.order</field>
        <field name="view_mode">tree,form</field>
        <field name="view_ids" eval="[
            Command.clear(),
            (0, 0, {'view_mode': 'tree', 'view_id': ref('view_purchase_order_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_purchase_order_form')}),
        ]"/>
    </record>

</odoo>