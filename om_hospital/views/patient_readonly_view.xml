<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree View -->
    <record id="view_om_readonly_patient_tree" model="ir.ui.view">
        <field name="name">hospital.patient.readonly.tree</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <tree string="View Patients" create="0" edit="0" delete="0">
                <field name="name"/>
                <field name="age"/>
                <field name="gender" optional="show"/>
                <field name="phone" optional="hide"/>
                <field name="email" optional="hide"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_om_readonly_patient_form" model="ir.ui.view">
        <field name="name">hospital.patient.readonly.form</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <form string="View Patient" create="0" edit="0" delete="0">
                <sheet>
                    <group>
                        <group string="Personal Info">
                            <field name="name"/>
                            <field name="age"/>
                            <field name="gender"/>
                            <field name="date_of_birth"/>
                            <field name="active"/>
                        </group>
                        <group string="Contact Info">
                            <field name="phone"/>
                            <field name="email"/>
                            <field name="address"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_om_readonly_patient" model="ir.actions.act_window">
        <field name="name">View Patients</field>
         <field name="view_ids" eval="[
                    Command.clear(),
                    (0, 0, {'view_mode': 'tree', 'view_id': ref('view_om_readonly_patient_tree')}),
                    (0, 0, {'view_mode': 'form', 'view_id': ref('view_om_readonly_patient_form')})
                ]"/>
        <field name="res_model">hospital.patient</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>