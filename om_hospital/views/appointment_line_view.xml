<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_om_appointment_line_tree" model="ir.ui.view">
        <field name="name">hospital.appointment.line.tree</field>
        <field name="model">hospital.appointment.line</field>
        <field name="arch" type="xml">
            <tree string="Appointments Line" editable="top">
                <field name="appointment_id"/>
                <field name="product_id"/>
                <field name="quantity"/>
            </tree>
        </field>
    </record>


    <record id="action_om_appointment_line" model="ir.actions.act_window">
        <field name="name">Appointments Line</field>
        <field name="res_model">hospital.appointment.line</field>
        <field name="view_mode">tree</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No appointments found. Click to create your first appointment.
            </p>
        </field>
    </record>
</odoo>