<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_om_patient_search" model="ir.ui.view">
        <field name="name">hospital.patient.search</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <search string="Patients">
                <field name="name"
                       filter_domain="['|', '|', '|',
                           ('name', 'ilike', self),
                           ('phone', 'ilike', self),
                           ('email', 'ilike', self),
                           ('address', 'ilike', self)]"
                       string="Search"/>
                <filter string="Male" name="male_patients" domain="['|', ('gender', '=', 'male'), ('gender', '=', False)]"/>
                <filter string="Female" name="female_patients" domain="['|', ('gender', '=', 'female'), ('gender', '=', False)]"/>
            </search>
        </field>
    </record>
    <!-- Tree View -->
    <record id="view_om_patient_tree" model="ir.ui.view">
        <field name="name">hospital.patient.tree</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <tree string="Patients">
                <field name="image_128" widget="image" string="Photo"  class="o_patient_photo"/>
                <field name="name"/>
                <field name="age"/>
                <field name="date_of_birth" string="Date of Birth"/>
                <field name="active"/>
                <field name="address" optional="hide"/>
                <field name="gender" optional="show"/>
                <field name="phone" optional="hide"/>
                <field name="email" optional="hide"/>
                <field name="tag_ids" widget="many2many_tags" optional="hide"/>
            </tree>
        </field>
    </record>
    <!-- Form View -->
    <record id="view_om_patient_form" model="ir.ui.view">
        <field name="name">hospital.patient.form</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group string="Personal Info">
                            <field name="name"/>
                            <field name="age"/>
                            <field name="gender"/>
                            <field name="date_of_birth" string="Date of Birth"/>
                            <field name="active"/>
                            <field name="image_1920" widget="image" class="oe_avatar"/>
                        </group>
                        <group string="Tags">
                            <field name="tag_ids" widget="many2many_tags" />
                        </group>
                        <group string="Contact Info">
                            <field name="phone"/>
                            <field name="email" />
                            <field name="address"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_om_patient" model="ir.actions.act_window">
        <field name="name">Patients</field>
        <field name="view_ids" eval="[
                    Command.clear(),
                    (0, 0, {'view_mode': 'tree', 'view_id': ref('view_om_patient_tree')}),
                    (0, 0, {'view_mode': 'form', 'view_id': ref('view_om_patient_form')})
                ]"/>
        <field name="res_model">hospital.patient</field>
        <field name="context">{'create': False}</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>