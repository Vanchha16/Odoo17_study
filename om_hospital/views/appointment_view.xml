<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_om_appointment_tree" model="ir.ui.view">
        <field name="name">hospital.appointment.tree</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <tree string="Appointments">
                <field name="patient_id"/>
                <field name="reference"/>
                <field name="create_uid" groups="om_hospital.group_hospital_doctors"/>
                <field name="date_appointment"/>
                <field name="note" optional="show"/>
            </tree>
        </field>
    </record>

    <record id="view_om_appointment_form" model="ir.ui.view">
        <field name="name">hospital.appointment.form</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <form string="Appointment">
                <header>
                    <field name="state" widget="statusbar"/>
                    <button name="action_confirm" type="object" string="Confirm"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_cancel" type="object" string="Cancel"
                            class="btn-secondary"
                            invisible="state != 'confirmed'"/>
                    <button name="action_set_draft" type="object" string="Set to Draft"
                            class="btn-secondary"
                            invisible="state != 'cancelled'"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="reference" readonly="True"/>
                            <field name="patient_id"/>
                            <field name="date_of_birth"/>
                            <field name="date_appointment"/>
                            <field name="note"/>
                        </group>
                        <group>
                            <field name="total_qty"/>
                            <field name="create_uid" groups="om_hospital.group_hospital_doctors"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Appointment Lines" icon="fa-solid fa-list" name="appointment_lines">
                            <field name="appointment_line_ids">
                                <tree editable="bottom">
                                    <field name="product_id"/>
                                    <field name="quantity"/>
                                </tree>
                            </field>
                        </page>
                        <page name="Other Information" icon="fa-solid fa-info-circle">
                            <group>
                                <field name="create_date" readonly="True"/>
                                <field name="write_date" readonly="True"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>

                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_om_appointment" model="ir.actions.act_window">
        <field name="name">Appointments</field>
        <field name="res_model">hospital.appointment</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No appointments found. Click to create your first appointment.
            </p>
        </field>
    </record>
</odoo>